# Production Environment - Configure these in deployment platform
# Do NOT commit real values to git

# Authentication
NEXTAUTH_SECRET=REPLACE_WITH_REAL_SECRET
NEXTAUTH_URL=REPLACE_WITH_REAL_URL

# Azure SQL Database
AZURE_SQL_SERVER=REPLACE_WITH_REAL_SERVER
AZURE_SQL_DATABASE=REPLACE_WITH_REAL_DATABASE
AZURE_SQL_USER=REPLACE_WITH_REAL_USER
AZURE_SQL_PASSWORD=REPLACE_WITH_REAL_PASSWORD
AZURE_SQL_PORT=1433

# Public API
NEXT_PUBLIC_API_BASE_URL=REPLACE_WITH_REAL_API_URL
