# Environment Variables Template
# Copy this file to .env.local and fill in the real values for local development
# For production, configure these in the deployment platform (Vercel, Azure, etc.)

# ========================================
# AUTHENTICATION
# ========================================
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ========================================
# AZURE SQL DATABASE
# ========================================
# Connection String (alternative to individual params)
DATABASE_URL=

# Individual parameters (if not using DATABASE_URL)
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=
AZURE_SQL_PORT=1433

# ========================================
# API CONFIGURATION
# ========================================
NEXT_PUBLIC_API_BASE_URL=

# ========================================
# DEPLOYMENT REFERENCE
# ========================================
# For local development:
#   NEXTAUTH_URL=http://localhost:3000
#   AZURE_SQL_SERVER=srv-opticolor.database.windows.net
#   AZURE_SQL_DATABASE=db-opticolor-dw
#
# For Vercel/Azure:
#   NEXTAUTH_URL=https://<your-domain>.vercel.app or https://<your-app>.azurewebsites.net
#   Configure other variables in the platform dashboard or Azure Key Vault
